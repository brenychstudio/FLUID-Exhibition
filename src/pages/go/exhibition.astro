<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Redirecting…</title>
    <meta http-equiv="refresh" content="0;url=/en/exhibition" />
  </head>

  <body style="background:#0b0b0c;color:#f5f3ef;font-family:Inter,system-ui,sans-serif;">
    <script is:inline>
      const lang = navigator.language.toLowerCase();
      const locale = lang.startsWith("ca") ? "ca" : lang.startsWith("es") ? "es" : "en";
      window.location.replace(`/${locale}/exhibition`);
    </script>

    <p style="padding:24px;">Redirecting to exhibition…</p>
  </body>
</html>
