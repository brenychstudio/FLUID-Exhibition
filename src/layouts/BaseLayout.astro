---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import LanguageSwitch from "../components/site/LanguageSwitch.astro";
import FluidAmbientCanvas from "../components/preview/FluidAmbientCanvas.tsx";
import type { Locale } from "../lib/i18n";

interface Props {
  title?: string;
  description?: string;
  locale: Locale;
  pathNoLocale: string;
  hideHeader?: boolean;
  hideAmbient?: boolean;
}

const {
  title = "FLUID — QR Fluid",
  description = "FLUID exhibition microsite with artist pages, multilingual navigation, and QR-driven experience.",
  locale,
  pathNoLocale,
  hideHeader = false,
  hideAmbient = false,
} = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="shortcut icon" href="/favicon.svg?v=2" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/exhibition/poster/fluid-poster.jpg" />
    <meta property="og:image:alt" content="FLUID — exhibition preview" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/exhibition/poster/fluid-poster.jpg" />
    <ClientRouter />
  </head>

  <body>
    {!hideAmbient && <FluidAmbientCanvas client:load />}

    <div class="site-shell">
      <div class="content-layer">
        {!hideHeader && (
          <header class="sticky top-0 z-40 px-3 pt-3 md:px-5 md:pt-4">
            <div class="container-premium">
              <div class="fluid-topbar px-4 py-3 md:px-5">
                <a
                  href={`/${locale}/exhibition`}
                  class="text-xs font-semibold tracking-[0.34em] uppercase text-white/90"
                >
                  QR FLUID
                </a>

                <LanguageSwitch locale={locale} pathNoLocale={pathNoLocale} />
              </div>
            </div>
          </header>
        )}

        <main class={hideHeader ? "" : "pb-16 md:pb-24"}>
          <slot />
        </main>

        <footer class="px-3 pb-6 md:px-5 md:pb-8">
          <div class="container-premium">
            <div class="flex justify-end">
              <a
                href="https://www.instagram.com/koolberk/"
                target="_blank"
                rel="noreferrer"
                class="text-[11px] uppercase tracking-[0.22em] text-white/44 transition hover:text-white/72"
              >
                Design & development — brenychstudio
              </a>
            </div>
          </div>
        </footer>
      </div>
    </div>
  </body>
</html>
